# ─────────────────────────────────────────────────────────────────────
# DevPulse Architect — configuration. Copy to .env and fill in.
# On a host (e.g. Render) set these as environment variables instead.
# ─────────────────────────────────────────────────────────────────────

# ── AI model (configured here, never in the UI) ──────────────────────
# Which provider + model to use for chat, project explanations, and the
# LLM audit pass.
LLM_PROVIDER=gemini          # gemini | openai | anthropic
LLM_MODEL=gemini-2.5-flash   # e.g. gemini-2.5-flash, gpt-4o, claude-opus-4-8

# Provide the key for the provider you selected above. Gemini also powers
# semantic-search embeddings (gemini-embedding-001) regardless of provider.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Authentication — persistent account store ────────────────────────
# Preferred: Supabase. Project URL + the SERVICE ROLE key (Project Settings →
# API). Accounts live in a `devpulse_users` table and survive redeploys.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# If SUPABASE_* are empty, the app falls back to a local SQLite file (auth.db) —
# fine for local dev, but ephemeral on hosts like Render (accounts reset on
# redeploy). Configure Supabase above for production.

# A long, random secret used to sign the login session cookie. Keep it stable
# so sessions survive restarts. Generate e.g. with: python -c "import secrets;print(secrets.token_hex(32))"
AUTH_COOKIE_KEY=
