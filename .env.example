# API keys are optional here — you can paste them directly in the app's Settings page.
# Values set here (or as host environment variables, e.g. on Render) act as the
# fallback when no key has been entered in the UI for that provider.

# Google Gemini. Also powers semantic search embeddings (text-embedding-004),
# independently of which chat provider you select.
GEMINI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=
